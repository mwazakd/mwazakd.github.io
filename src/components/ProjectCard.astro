---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  slug?: string;
}

const { project, slug } = Astro.props;
const href = slug ? `/projects/${slug}` : undefined;
---

<div class="bg-slate-800 rounded-lg overflow-hidden shadow-lg hover:shadow-2xl hover:shadow-sky-500/20 transition-all duration-300 transform hover:-translate-y-2 group h-full flex flex-col">
  <a href={href} class:list={[!href && 'pointer-events-none']}>
    <div class="relative overflow-hidden">
      <img src={project.data.image} alt={project.data.title} class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300" />
      <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all duration-300"></div>
      {project.data.status !== 'complete' && (
        <span class="absolute top-3 right-3 px-2 py-1 text-xs font-semibold rounded-full bg-slate-900/80 text-sky-300 capitalize">
          {project.data.status.replace('-', ' ')}
        </span>
      )}
    </div>
  </a>
  <div class="p-6 flex flex-col flex-grow">
    {href ? (
      <a href={href} class="text-xl font-bold text-white mb-2 hover:text-sky-400 transition-colors">{project.data.title}</a>
    ) : (
      <h3 class="text-xl font-bold text-white mb-2">{project.data.title}</h3>
    )}
    <p class="text-slate-400 mb-4 text-sm flex-grow">{project.data.description}</p>
    <div class="flex flex-wrap gap-2 mb-4">
      {project.data.tags.map((tag) => (
        <span class="bg-sky-500/20 text-sky-300 text-xs font-semibold px-3 py-1 rounded-full">{tag}</span>
      ))}
    </div>
    <div class="flex items-center space-x-4 mt-auto">
      {project.data.sourceUrl && (
        <a href={project.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-sky-400 transition-colors flex items-center gap-2 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          Source
        </a>
      )}
      {project.data.liveUrl && (
        <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-sky-400 transition-colors flex items-center gap-2 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
          Live Demo
        </a>
      )}
    </div>
  </div>
</div>
