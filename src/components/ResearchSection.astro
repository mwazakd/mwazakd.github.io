---
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
---

<p class="max-w-3xl mx-auto text-center text-slate-400 mb-12">
  These areas reflect my current research interests and the directions I hope to explore in developing AI that is inclusive, data-efficient, and grounded in real-world contexts.
</p>
<div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {site.researchInterests.map((interest) => (
    <div class="bg-slate-800 p-6 rounded-lg shadow-lg flex flex-col h-full hover:shadow-2xl hover:shadow-sky-500/20 transition-all duration-300 transform hover:-translate-y-2 border-l-4 border-slate-700 hover:border-sky-500">
      <h3 class="text-xl font-bold mb-3 text-slate-100">{interest.title}</h3>
      <p class="text-slate-400 leading-relaxed">{interest.description}</p>
    </div>
  ))}
</div>
