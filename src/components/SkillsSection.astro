---
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
---

<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {site.skills.map((category) => (
    <div class="bg-slate-800 p-6 rounded-lg shadow-lg hover:shadow-2xl hover:shadow-sky-500/20 transition-all duration-300">
      <h3 class="text-xl font-bold text-slate-100 mb-4 border-b border-slate-700 pb-2">{category.title}</h3>
      <div class="flex flex-wrap gap-2">
        {category.skills.map((skill) => (
          <span class="px-3 py-1.5 bg-slate-700 text-slate-200 text-sm rounded-md hover:bg-sky-500 hover:text-white transition-colors duration-200">{skill}</span>
        ))}
      </div>
    </div>
  ))}
</div>
