---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const statusLabel = project.data.status.replace('-', ' ');
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="max-w-4xl mx-auto py-8">
    <a href="/projects" class="text-sky-400 hover:text-sky-300 text-sm mb-6 inline-block">← Back to Projects</a>
    <img src={project.data.image} alt={project.data.title} class="w-full h-64 md:h-80 object-cover rounded-lg mb-8" />
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="px-3 py-1 text-xs font-semibold rounded-full bg-slate-800 text-sky-300 capitalize">{statusLabel}</span>
      {project.data.tags.map((tag) => (
        <span class="bg-sky-500/20 text-sky-300 text-xs font-semibold px-3 py-1 rounded-full">{tag}</span>
      ))}
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{project.data.title}</h1>
    <p class="text-lg text-slate-400 mb-8">{project.data.description}</p>
    <div class="flex flex-wrap gap-4 mb-8">
      {project.data.sourceUrl && (
        <a href={project.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-slate-800 text-slate-300 px-4 py-2 rounded-lg hover:bg-slate-700 transition-colors">
          View Source
        </a>
      )}
      {project.data.liveUrl && (
        <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-sky-500 text-white px-4 py-2 rounded-lg hover:bg-sky-600 transition-colors">
          Live Demo
        </a>
      )}
    </div>
    <div class="prose prose-invert prose-sky max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
