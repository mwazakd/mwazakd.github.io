---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
---

<BaseLayout title="Resume" description="Resume and CV of Kudzaishe Mwaza.">
  <Section title="Resume">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-lg text-slate-400 mb-8">
        Download my CV or connect with me on LinkedIn for a full professional history.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-12">
        <a
          href={site.cvUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-sky-500 text-white font-bold py-3 px-8 rounded-full hover:bg-sky-600 transition-all duration-300 shadow-lg shadow-sky-500/30"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
          Download CV (PDF)
        </a>
        <a
          href={site.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-slate-800 text-slate-300 font-bold py-3 px-8 rounded-full hover:bg-slate-700 transition-all duration-300 border border-slate-700"
        >
          View LinkedIn
        </a>
      </div>

      <div class="text-left bg-slate-800 p-8 rounded-lg border border-slate-700">
        <h3 class="text-xl font-bold text-white mb-4">Highlights</h3>
        <ul class="space-y-3 text-slate-400">
          <li class="flex items-start gap-2"><span class="text-sky-400">▸</span> BEng Mechatronics Engineering, University of Zimbabwe (2.1)</li>
          <li class="flex items-start gap-2"><span class="text-sky-400">▸</span> STEM tutor — Physics, Mathematics, Programming (2020–Present)</li>
          <li class="flex items-start gap-2"><span class="text-sky-400">▸</span> Google Earth Engine — water quality monitoring for Zimbabwean water bodies</li>
          <li class="flex items-start gap-2"><span class="text-sky-400">▸</span> Educational technology — 3D titration simulator and e-learning platforms</li>
          <li class="flex items-start gap-2"><span class="text-sky-400">▸</span> Research interests: educational robotics, human-centered AI, low-resource ML</li>
        </ul>
      </div>
    </div>
  </Section>
</BaseLayout>
