---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ResearchSection from '../components/ResearchSection.astro';
import TeachingSection from '../components/TeachingSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import { getCollection } from 'astro:content';
import { getSiteConfig, formatDateShort } from '../lib/site';
import {
  HOMEPAGE_DESKTOP_LIMIT,
  HOMEPAGE_NEWS_LIMIT,
  homeItemVisibilityClass,
  homepageCardGridClass,
  projectStatusOrder,
} from '../lib/homepage';

const site = getSiteConfig();

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, HOMEPAGE_NEWS_LIMIT);

const allProjects = await getCollection('projects');
const homepageProjects = allProjects
  .sort((a, b) => projectStatusOrder[a.data.status] - projectStatusOrder[b.data.status])
  .slice(0, HOMEPAGE_DESKTOP_LIMIT);

const allBlog = await getCollection('blog', ({ data }) => !data.draft);
const homepageArticles = allBlog
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, HOMEPAGE_DESKTOP_LIMIT);
---

<BaseLayout>
  <Hero />

  <Section title="Research">
    <ResearchSection />
  </Section>

  <Section title="Teaching & Mentoring">
    <TeachingSection />
  </Section>

  <Section title="My Projects">
    <div class={homepageCardGridClass}>
      {homepageProjects.map((project, index) => (
        <div class={homeItemVisibilityClass(index)}>
          <ProjectCard project={project} slug={project.id} />
        </div>
      ))}
    </div>
    {allProjects.length > HOMEPAGE_DESKTOP_LIMIT && (
      <div class="mt-8 text-center">
        <a href="/projects" class="text-sky-400 hover:text-sky-300 font-medium">View all projects →</a>
      </div>
    )}
  </Section>

  {homepageArticles.length > 0 && (
    <Section title="Articles">
      <div class={homepageCardGridClass}>
        {homepageArticles.map((post, index) => (
          <div class={homeItemVisibilityClass(index)}>
            <ArticleCard post={post} slug={post.id} />
          </div>
        ))}
      </div>
      {allBlog.length > HOMEPAGE_DESKTOP_LIMIT && (
        <div class="mt-8 text-center">
          <a href="/blog" class="text-sky-400 hover:text-sky-300 font-medium">View all articles →</a>
        </div>
      )}
    </Section>
  )}

  <Section title="Skills">
    <SkillsSection />
  </Section>

  <Section title="Recent News">
    <div class="max-w-2xl mx-auto bg-slate-800/50 p-6 rounded-lg border-2 border-slate-700 shadow-lg">
      <h3 class="font-bold text-sm mb-6 text-red-500 tracking-widest">RECENT NEWS</h3>
      <ul class="space-y-4">
        {latestNews.map((item) => (
          <li class="flex gap-4 pb-4 border-b border-slate-700 last:border-0">
            <span class="text-slate-500 font-mono text-xs whitespace-nowrap pt-1">{formatDateShort(item.data.date)}</span>
            <div>
              {item.data.link ? (
                <a href={item.data.link} class="text-slate-300 text-base hover:text-sky-400 transition-colors">{item.data.summary}</a>
              ) : (
                <p class="text-slate-300 text-base">{item.data.summary}</p>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section title="About">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-slate-400 mb-6">{site.bio[0]}</p>
      <a href="/about" class="inline-block bg-sky-500 text-white font-bold py-3 px-8 rounded-full hover:bg-sky-600 transition-all duration-300">Learn more about me</a>
    </div>
  </Section>
</BaseLayout>
