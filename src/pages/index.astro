---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { getSiteConfig, formatDateShort } from '../lib/site';

const site = getSiteConfig();

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const allProjects = await getCollection('projects');
const featuredProject = allProjects.find((p) => p.data.featured) ?? allProjects[0];

const allBlog = await getCollection('blog', ({ data }) => !data.draft);
const featuredArticle = allBlog.find((p) => p.data.featured)
  ?? allBlog.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

<BaseLayout>
  <Hero />

  <Section title="Latest News">
    <div class="max-w-2xl mx-auto bg-slate-800/50 p-6 rounded-lg border-2 border-slate-700 shadow-lg">
      <h3 class="font-bold text-sm mb-6 text-red-500 tracking-widest">RECENT NEWS</h3>
      <ul class="space-y-4">
        {latestNews.map((item) => (
          <li class="flex gap-4 pb-4 border-b border-slate-700 last:border-0">
            <span class="text-slate-500 font-mono text-xs whitespace-nowrap pt-1">{formatDateShort(item.data.date)}</span>
            <div>
              {item.data.link ? (
                <a href={item.data.link} class="text-slate-300 text-base hover:text-sky-400 transition-colors">{item.data.summary}</a>
              ) : (
                <p class="text-slate-300 text-base">{item.data.summary}</p>
              )}
            </div>
          </li>
        ))}
      </ul>
      <div class="mt-6 text-center">
        <a href="/blog" class="text-sky-400 hover:text-sky-300 text-sm font-medium">View all updates →</a>
      </div>
    </div>
  </Section>

  {featuredProject && (
    <Section title="Featured Project">
      <div class="max-w-2xl mx-auto">
        <ProjectCard project={featuredProject} slug={featuredProject.id} />
      </div>
      <div class="mt-8 text-center">
        <a href="/projects" class="text-sky-400 hover:text-sky-300 font-medium">View all projects →</a>
      </div>
    </Section>
  )}

  {featuredArticle && (
    <Section title="Featured Article">
      <div class="max-w-2xl mx-auto bg-slate-800 p-8 rounded-lg border border-slate-700 hover:border-sky-500/50 transition-colors">
        <span class="text-xs font-semibold text-sky-400 uppercase tracking-wider">{featuredArticle.data.category}</span>
        <h3 class="text-2xl font-bold text-white mt-2 mb-3">
          <a href={`/blog/${featuredArticle.id}`} class="hover:text-sky-400 transition-colors">{featuredArticle.data.title}</a>
        </h3>
        <p class="text-slate-500 text-sm mb-4">{formatDateShort(featuredArticle.data.date)}</p>
        <a href={`/blog/${featuredArticle.id}`} class="text-sky-400 hover:text-sky-300 font-medium">Read article →</a>
      </div>
      <div class="mt-8 text-center">
        <a href="/blog" class="text-sky-400 hover:text-sky-300 font-medium">View all articles →</a>
      </div>
    </Section>
  )}

  <Section title="Current Focus">
    <div class="max-w-2xl mx-auto">
      <ul class="space-y-3">
        {site.currentFocus.map((item) => (
          <li class="flex items-start gap-3 text-slate-300">
            <span class="text-sky-400 mt-1">▸</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section title="About">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-slate-400 mb-6">{site.bio[0]}</p>
      <a href="/about" class="inline-block bg-sky-500 text-white font-bold py-3 px-8 rounded-full hover:bg-sky-600 transition-all duration-300">Learn more about me</a>
    </div>
  </Section>
</BaseLayout>
