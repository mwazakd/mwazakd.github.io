---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { formatDate, getSiteConfig } from '../../lib/site';
import { getPapers } from '../../lib/content';

const site = getSiteConfig();
const papers = (await getPapers()).sort(
  (a, b) => b.data.dateRead.getTime() - a.data.dateRead.getTime()
);
---

<BaseLayout title="Research" description="Research papers, reading notes, and academic interests.">
  <Section title="Research">
    <p class="max-w-3xl mx-auto text-center text-slate-400 mb-12">
      Papers I&apos;ve read, research notes, and areas I&apos;m exploring for graduate study and beyond.
    </p>

    <div class="max-w-4xl mx-auto mb-16">
      <h3 class="text-xl font-bold text-slate-100 mb-6 border-b border-slate-700 pb-2">Papers I&apos;ve Read</h3>
      {papers.length === 0 ? (
        <p class="text-slate-500 italic">No papers logged yet. Check back soon — I&apos;ll be adding notes as I read.</p>
      ) : (
        <div class="space-y-6">
          {papers.map((paper) => (
            <article class="bg-slate-800 p-6 rounded-lg border border-slate-700 hover:border-sky-500/50 transition-colors">
              <h4 class="text-lg font-bold text-white mb-1">
                <a href={`/research/papers/${paper.id}`} class="hover:text-sky-400 transition-colors">{paper.data.title}</a>
              </h4>
              <p class="text-slate-500 text-sm mb-2">{paper.data.authors.join(', ')}</p>
              <p class="text-slate-400 text-sm mb-3">{paper.data.summary}</p>
              <div class="flex flex-wrap gap-2">
                {paper.data.tags.map((tag) => (
                  <span class="text-xs bg-slate-700 text-slate-300 px-2 py-1 rounded">{tag}</span>
                ))}
                <span class="text-xs text-slate-500 ml-auto">{formatDate(paper.data.dateRead)}</span>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>

    <div class="max-w-4xl mx-auto">
      <h3 class="text-xl font-bold text-slate-100 mb-6 border-b border-slate-700 pb-2">Research Interests</h3>
      <p class="text-slate-400 mb-8 text-center">
        These areas reflect my current research interests and the directions I hope to explore.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {site.researchInterests.map((interest) => (
          <div class="bg-slate-800 p-6 rounded-lg shadow-lg flex flex-col h-full hover:shadow-2xl hover:shadow-sky-500/20 transition-all duration-300 transform hover:-translate-y-2 border-l-4 border-slate-700 hover:border-sky-500">
            <h4 class="text-xl font-bold mb-3 text-slate-100">{interest.title}</h4>
            <p class="text-slate-400 leading-relaxed">{interest.description}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>
</BaseLayout>
