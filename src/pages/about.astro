---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ResearchSection from '../components/ResearchSection.astro';
import TeachingSection from '../components/TeachingSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ContactForm from '../components/ContactForm';
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
---

<BaseLayout title="About" description="About Kudzaishe Mwaza — STEM educator, researcher, and tech enthusiast.">
  <Section title="About Me">
    <div class="max-w-3xl mx-auto space-y-4 mb-12">
      {site.bio.map((paragraph) => (
        <p class="text-slate-400 text-lg leading-relaxed">{paragraph}</p>
      ))}
    </div>
  </Section>

  <Section title="Research Interests">
    <ResearchSection />
  </Section>

  <Section title="Teaching & Mentoring">
    <TeachingSection />
  </Section>

  <Section title="Skills">
    <SkillsSection />
  </Section>

  <Section title="Get in Touch">
    <ContactForm client:load email={site.email} linkedin={site.linkedin} />
  </Section>
</BaseLayout>
